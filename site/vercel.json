{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile && pnpm --dir .. install --frozen-lockfile --ignore-scripts",
  "buildCommand": "pnpm --dir .. build:embed && pnpm build",
  "redirects": [
    {
      "source": "/download",
      "destination": "https://github.com/ethylon/amont/releases/latest",
      "permanent": false
    }
  ]
}

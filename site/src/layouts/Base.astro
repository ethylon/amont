---
import { getImage } from "astro:assets"
import "../styles/global.css"
import geistWoff2 from "@fontsource-variable/geist/files/geist-latin-wght-normal.woff2?url"
import { dict, DOWNLOAD_URL, REPO_URL, type Locale } from "../i18n/ui"
import graphLight from "../../../docs/graph-light.png"
import pkg from "../../../package.json"

interface Props {
  locale: Locale
  /** Page title/description; the landing's meta is the default. */
  title?: string
  description?: string
  /** Per-locale route of the current page, for canonical + hreflang. */
  paths?: Record<Locale, string>
}

const { locale, paths = { en: "/", fr: "/fr/" } } = Astro.props
const t = dict[locale]
const title = Astro.props.title ?? t.meta.title
const description = Astro.props.description ?? t.meta.description

const og = await getImage({ src: graphLight, width: 1200, height: 630, fit: "cover", format: "jpg" })
const ogUrl = new URL(og.src, Astro.site)
const canonical = new URL(paths[locale], Astro.site)
const alternates: { hreflang: string; href: URL }[] = [
  { hreflang: "en", href: new URL(paths.en, Astro.site) },
  { hreflang: "fr", href: new URL(paths.fr, Astro.site) },
  { hreflang: "x-default", href: new URL(paths.en, Astro.site) },
]

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "@id": new URL("/#app", Astro.site),
      name: "Amont",
      operatingSystem: "Windows",
      applicationCategory: "DeveloperApplication",
      applicationSubCategory: "Git client",
      description: t.meta.description,
      softwareVersion: pkg.version,
      url: canonical,
      downloadUrl: DOWNLOAD_URL,
      screenshot: ogUrl,
      image: ogUrl,
      license: `${REPO_URL}/blob/main/LICENSE`,
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      author: { "@type": "Person", name: "Mathieu Guey" },
      sameAs: [REPO_URL],
      inLanguage: ["en", "fr"],
    },
    {
      "@type": "WebSite",
      "@id": new URL("/#website", Astro.site),
      url: Astro.site,
      name: "Amont",
      description: t.meta.description,
      inLanguage: locale,
    },
  ],
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <link rel="preload" href={geistWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#09090b" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Amont" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t.hero.graphAlt} />
    <meta property="og:locale" content={locale === "en" ? "en_US" : "fr_FR"} />
    <meta property="og:locale:alternate" content={locale === "en" ? "fr_FR" : "en_US"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogUrl} />
    <meta name="twitter:image:alt" content={t.hero.graphAlt} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline>
      // Before first paint: mark JS as available (gates the reveal animations) and
      // resolve the theme: stored choice first, OS preference otherwise.
      document.documentElement.classList.add("js")
      const stored = localStorage.getItem("theme")
      const dark = stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches
      document.documentElement.classList.toggle("dark", dark)
    </script>
  </head>
  <body class="bg-white font-sans text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100">
    <slot />
    <script>
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible")
              io.unobserve(entry.target)
            }
          }
        },
        { threshold: 0.15, rootMargin: "0px 0px -40px 0px" }
      )
      document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el))
    </script>
  </body>
</html>

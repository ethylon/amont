---
// L'artefact "command transparency" : la console lecture seule d'Amont, peuplée de
// vraies commandes. Toujours sur surface sombre (île Trust), quel que soit le thème.
import Icon from "./Icon.astro"
import { CommandLineIcon } from "@hugeicons/core-free-icons"

interface Props {
  label: string
}

const { label } = Astro.props

const lines = [
  { cmd: "git", rest: "fetch origin --prune" },
  { cmd: "git", rest: "log --date-order -n 1000 --all" },
  { cmd: "git", rest: 'stash push -m "wip: sticky header"' },
  { cmd: "git", rest: "add -- src/cart.ts" },
  { cmd: "git", rest: 'commit -m "feat: review model"' },
  { cmd: "git", rest: "merge --no-ff feature/checkout-flow" },
  { cmd: "git", rest: "push origin main" },
]
---

<figure class="overflow-hidden rounded-xl border border-white/10 bg-zinc-950/70 shadow-lg shadow-black/30">
  <figcaption
    class="flex items-center gap-2 border-b border-white/10 px-4 py-2.5 font-mono text-xs text-zinc-500"
  >
    <Icon icon={CommandLineIcon} class="size-3.5" strokeWidth={1.5} />
    {label}
  </figcaption>
  <div class="space-y-1.5 overflow-x-auto px-4 py-4 font-mono text-[13px] leading-relaxed">
    {
      lines.map((line) => (
        <p class="whitespace-nowrap">
          <span class="text-zinc-600 select-none">›&nbsp;</span>
          <span class="text-zinc-500">{line.cmd}</span>
          <span class="text-zinc-200">&nbsp;{line.rest}</span>
        </p>
      ))
    }
  </div>
</figure>

---
// Ciel étoilé du hero : un champ fixe de points (les commits lointains), à très
// faible opacité, qui scintillent lentement. Décoratif ; les points sont visibles
// par défaut et le twinkle ne fait que moduler l'opacité autour de cet état.
---

<svg
  viewBox="0 0 1440 800"
  fill="none"
  aria-hidden="true"
  class="pointer-events-none absolute inset-0 -z-20 h-full w-full text-zinc-400/25 dark:text-zinc-500/40"
  style="mask-image: linear-gradient(to bottom, black 0%, black 60%, transparent 92%); -webkit-mask-image: linear-gradient(to bottom, black 0%, black 60%, transparent 92%)"
  preserveAspectRatio="xMidYMin slice"
>
  <g fill="currentColor">
    <circle class="tw1" cx="48" cy="64" r="1.3"></circle>
    <circle class="tw2" cx="132" cy="212" r="1"></circle>
    <circle class="tw3" cx="94" cy="388" r="1.6"></circle>
    <circle class="tw2" cx="211" cy="96" r="1"></circle>
    <circle class="tw1" cx="263" cy="301" r="1.3"></circle>
    <circle class="tw3" cx="177" cy="502" r="1"></circle>
    <circle class="tw2" cx="342" cy="158" r="1.6"></circle>
    <circle class="tw1" cx="398" cy="47" r="1"></circle>
    <circle class="tw3" cx="451" cy="243" r="1.3"></circle>
    <circle class="tw2" cx="379" cy="429" r="1"></circle>
    <circle class="tw1" cx="521" cy="118" r="1"></circle>
    <circle class="tw3" cx="568" cy="336" r="1.6"></circle>
    <circle class="tw2" cx="614" cy="71" r="1.3"></circle>
    <circle class="tw1" cx="672" cy="214" r="1"></circle>
    <circle class="tw3" cx="705" cy="456" r="1"></circle>
    <circle class="tw2" cx="748" cy="129" r="1.6"></circle>
    <circle class="tw1" cx="807" cy="342" r="1"></circle>
    <circle class="tw3" cx="851" cy="58" r="1.3"></circle>
    <circle class="tw2" cx="893" cy="247" r="1"></circle>
    <circle class="tw1" cx="922" cy="481" r="1.6"></circle>
    <circle class="tw3" cx="988" cy="152" r="1"></circle>
    <circle class="tw2" cx="1042" cy="333" r="1.3"></circle>
    <circle class="tw1" cx="1087" cy="84" r="1"></circle>
    <circle class="tw3" cx="1132" cy="424" r="1"></circle>
    <circle class="tw2" cx="1178" cy="203" r="1.6"></circle>
    <circle class="tw1" cx="1234" cy="512" r="1"></circle>
    <circle class="tw3" cx="1289" cy="97" r="1.3"></circle>
    <circle class="tw2" cx="1337" cy="296" r="1"></circle>
    <circle class="tw1" cx="1394" cy="176" r="1.6"></circle>
    <circle class="tw3" cx="1418" cy="438" r="1"></circle>
    <circle class="tw2" cx="76" cy="547" r="1"></circle>
    <circle class="tw1" cx="308" cy="571" r="1.3"></circle>
    <circle class="tw3" cx="536" cy="529" r="1"></circle>
    <circle class="tw2" cx="641" cy="602" r="1"></circle>
    <circle class="tw1" cx="854" cy="568" r="1"></circle>
    <circle class="tw3" cx="1009" cy="611" r="1.3"></circle>
    <circle class="tw2" cx="1204" cy="644" r="1"></circle>
    <circle class="tw1" cx="1356" cy="587" r="1"></circle>
    <circle class="tw3" cx="238" cy="668" r="1"></circle>
    <circle class="tw1" cx="487" cy="691" r="1.3"></circle>

  </g>
  <g class="text-violet-500/40 dark:text-violet-400/45" fill="currentColor">
    <circle class="tw2" cx="296" cy="203" r="1.4"></circle>
    <circle class="tw1" cx="729" cy="288" r="1.4"></circle>
    <circle class="tw3" cx="1063" cy="516" r="1.4"></circle>
    <circle class="tw1" cx="1311" cy="371" r="1.4"></circle>
  </g>
</svg>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .tw1 {
      animation: twinkle 5.5s ease-in-out infinite;
    }
    .tw2 {
      animation: twinkle 7.3s ease-in-out -2.4s infinite;
    }
    .tw3 {
      animation: twinkle 9.1s ease-in-out -5.2s infinite;
    }
  }

  @keyframes twinkle {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.25;
    }
  }
</style>

---
import { Image } from "astro:assets"
import { dict, REPO_URL, localePath, type Locale } from "../i18n/ui"
import icon from "../../../resources/icon.png"

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const t = dict[locale]

const links = [
  { href: "#features", label: t.nav.features },
  { href: "#tour", label: t.nav.tour },
  { href: "#download", label: t.nav.download },
]
---

<header
  class="sticky top-0 z-50 border-b border-zinc-200/80 bg-white/80 backdrop-blur-md dark:border-zinc-800/80 dark:bg-zinc-950/80"
>
  <nav class="mx-auto flex h-16 max-w-6xl items-center gap-6 px-4 sm:px-6" aria-label="Main">
    <a href={localePath(locale)} class="flex items-center gap-2.5 font-semibold tracking-tight">
      <Image src={icon} alt="" width={56} densities={[1, 2]} class="size-7" loading="eager" />
      <span class="text-lg">Amont</span>
    </a>

    <div class="hidden items-center gap-6 text-sm text-zinc-600 sm:flex dark:text-zinc-400">
      {
        links.map((link) => (
          <a href={link.href} class="transition-colors hover:text-zinc-950 dark:hover:text-white">
            {link.label}
          </a>
        ))
      }
    </div>

    <div class="ml-auto flex items-center gap-1 text-sm">
      <a
        href={REPO_URL}
        rel="noopener"
        class="hidden rounded-md px-2.5 py-1.5 text-zinc-600 transition-colors hover:bg-zinc-100 hover:text-zinc-950 sm:block dark:text-zinc-400 dark:hover:bg-zinc-800/60 dark:hover:text-white"
      >
        GitHub <span aria-hidden="true">↗</span>
      </a>

      <div
        class="flex items-center gap-0.5 rounded-md border border-zinc-200 p-0.5 font-mono text-xs dark:border-zinc-800"
        role="group"
        aria-label="Language"
      >
        <a
          href="/"
          aria-current={locale === "en" ? "page" : undefined}
          class:list={[
            "rounded px-1.5 py-1 transition-colors",
            locale === "en"
              ? "bg-zinc-100 font-semibold text-zinc-950 dark:bg-zinc-800 dark:text-white"
              : "text-zinc-500 hover:text-zinc-950 dark:hover:text-white",
          ]}
        >
          EN
        </a>
        <a
          href="/fr/"
          aria-current={locale === "fr" ? "page" : undefined}
          class:list={[
            "rounded px-1.5 py-1 transition-colors",
            locale === "fr"
              ? "bg-zinc-100 font-semibold text-zinc-950 dark:bg-zinc-800 dark:text-white"
              : "text-zinc-500 hover:text-zinc-950 dark:hover:text-white",
          ]}
        >
          FR
        </a>
      </div>

      <button
        id="theme-toggle"
        type="button"
        aria-label={t.nav.theme}
        class="grid size-8 place-items-center rounded-md text-zinc-600 transition-colors hover:bg-zinc-100 hover:text-zinc-950 dark:text-zinc-400 dark:hover:bg-zinc-800/60 dark:hover:text-white"
      >
        <svg
          class="size-4.5 dark:hidden"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <svg
          class="hidden size-4.5 dark:block"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
          ></path>
        </svg>
      </button>
    </div>
  </nav>
</header>

<script>
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const dark = document.documentElement.classList.toggle("dark")
    localStorage.setItem("theme", dark ? "dark" : "light")
  })
</script>

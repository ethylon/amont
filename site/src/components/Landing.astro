---
import Base from "../layouts/Base.astro"
import Nav from "./Nav.astro"
import Shot from "./Shot.astro"
import GraphBg from "./GraphBg.astro"
import Starfield from "./Starfield.astro"
import HeroDemo from "./HeroDemo.astro"
import CommandLog from "./CommandLog.astro"
import Footer from "./Footer.astro"
import Icon from "./Icon.astro"
import { ArrowDown02Icon } from "@hugeicons/core-free-icons"
import { dict, REPO_URL, DOWNLOAD_URL, type Locale } from "../i18n/ui"

import graphLight from "../../../docs/graph-light.png"
import graphDark from "../../../docs/graph-dark.png"
import diffLight from "../../../docs/diff-light.png"
import diffDark from "../../../docs/diff-dark.png"
import worktreeLight from "../../../docs/worktree-light.png"
import worktreeDark from "../../../docs/worktree-dark.png"
import conflictLight from "../../../docs/conflict-light.png"
import conflictDark from "../../../docs/conflict-dark.png"

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const t = dict[locale]

const shots = {
  diff: { light: diffLight, dark: diffDark },
  worktree: { light: worktreeLight, dark: worktreeDark },
  conflict: { light: conflictLight, dark: conflictDark },
} as const
---

<Base locale={locale}>
  <a
    href="#main"
    class="sr-only focus-visible:not-sr-only focus-visible:fixed focus-visible:top-3 focus-visible:left-3 focus-visible:z-100 focus-visible:rounded-md focus-visible:bg-brand-600 focus-visible:px-4 focus-visible:py-2 focus-visible:text-white"
  >
    {locale === "en" ? "Skip to content" : "Aller au contenu"}
  </a>
  <Nav locale={locale} />

  <main id="main">
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <Starfield />
      <GraphBg />

      <div class="mx-auto max-w-6xl px-4 pt-20 sm:px-6 sm:pt-24">
        <div class="max-w-3xl">
          <h1 class="text-5xl font-semibold tracking-tighter text-balance sm:text-6xl lg:text-7xl">
            {t.hero.title}
          </h1>

          <p class="mt-6 max-w-2xl text-lg text-pretty text-zinc-600 dark:text-zinc-400">
            {t.hero.lede}
          </p>

          <div class="mt-9 flex flex-wrap items-center gap-x-7 gap-y-4">
            <a
              href={DOWNLOAD_URL}
              rel="noopener"
              class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-5 py-3 font-medium text-white transition-colors hover:bg-brand-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-600"
            >
              <Icon icon={ArrowDown02Icon} class="size-4.5" />
              {t.hero.ctaDownload}
            </a>
            <a
              href={REPO_URL}
              rel="noopener"
              class="font-medium text-zinc-600 transition-colors hover:text-zinc-950 dark:text-zinc-400 dark:hover:text-white"
            >
              {t.hero.ctaSource}
              <span aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </div>

      <div class="mx-auto max-w-6xl px-4 pt-14 sm:px-6 sm:pt-16">
        <HeroDemo
          light={graphLight}
          dark={graphDark}
          alt={t.hero.graphAlt}
          locale={locale}
          demoTitle={t.hero.demoTitle}
          demoHint={t.hero.demoHint}
          captionImage={t.hero.caption}
          captionDemo={t.hero.captionDemo}
        />
      </div>
    </section>

    <!-- The graph is the point -->
    <section id="graph">
      <div class="mx-auto max-w-6xl px-4 py-24 sm:px-6 sm:py-32">
        <h2 class="max-w-3xl text-2xl font-medium tracking-tight text-pretty sm:text-3xl" data-reveal>
          {t.graph.intro}
        </h2>

        <div class="mt-16 grid items-start gap-14 lg:grid-cols-2 lg:gap-10">
          <div data-reveal>
            <p class="text-7xl font-semibold tracking-tight tabular-nums sm:text-8xl">
              {t.graph.statValue}
            </p>
            <p class="mt-3 text-lg font-medium">{t.graph.statLabel}</p>
            <p class="mt-4 max-w-md leading-relaxed text-zinc-600 dark:text-zinc-400">
              {t.graph.statBody}
            </p>
          </div>

          <div class="space-y-12 lg:pt-3" data-reveal>
            <div>
              <h3 class="text-lg font-semibold tracking-tight">{t.graph.timeline.title}</h3>
              <p class="mt-3 max-w-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
                {t.graph.timeline.body}
              </p>
            </div>
            <div>
              <h3 class="text-lg font-semibold tracking-tight">{t.graph.keyboard.title}</h3>
              <p class="mt-3 max-w-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
                {t.graph.keyboard.body}
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Tour -->
    <section id="tour" class="border-t border-zinc-200 dark:border-zinc-800/80">
      <div class="mx-auto max-w-6xl px-4 py-24 sm:px-6 sm:py-32">
        <h2 class="max-w-2xl text-3xl font-semibold tracking-tight text-balance sm:text-4xl" data-reveal>
          {t.tour.heading}
        </h2>

        <div class="mt-16 space-y-24">
          {
            /* Les deux premiers arrêts alternent texte/image ; le dernier passe en
               pleine largeur pour casser le zigzag et donner sa place à la capture
               la plus spectaculaire (la résolution de conflits). */
            t.tour.stops.map((stop, index) =>
              index < t.tour.stops.length - 1 ? (
                <div class="grid items-center gap-8 lg:grid-cols-5 lg:gap-12" data-reveal>
                  <div class:list={["lg:col-span-2", index % 2 === 1 && "lg:order-last"]}>
                    <h3 class="text-2xl font-semibold tracking-tight text-balance">{stop.title}</h3>
                    <p class="mt-4 leading-relaxed text-zinc-600 dark:text-zinc-400">{stop.body}</p>
                  </div>
                  <div class="lg:col-span-3">
                    <Shot
                      light={shots[stop.shot].light}
                      dark={shots[stop.shot].dark}
                      alt={stop.alt}
                      sizes="(min-width: 1024px) 640px, 92vw"
                    />
                  </div>
                </div>
              ) : (
                <div data-reveal>
                  <div class="max-w-2xl">
                    <h3 class="text-2xl font-semibold tracking-tight text-balance">{stop.title}</h3>
                    <p class="mt-4 leading-relaxed text-zinc-600 dark:text-zinc-400">{stop.body}</p>
                  </div>
                  <Shot
                    light={shots[stop.shot].light}
                    dark={shots[stop.shot].dark}
                    alt={stop.alt}
                    class="mt-8"
                  />
                </div>
              )
            )
          }
        </div>
      </div>
    </section>

    <!-- Trust: it's still git -->
    <section id="trust" class="px-4 py-10 sm:px-6 sm:py-14">
      <div
        class="mx-auto max-w-6xl rounded-3xl bg-zinc-950 px-6 py-16 text-zinc-50 sm:px-12 sm:py-20 dark:border dark:border-zinc-800 dark:bg-zinc-900/40"
      >
        <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-16">
          <div data-reveal>
            <h2 class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl">
              {t.trust.heading}
            </h2>
            <p class="mt-4 text-lg text-pretty text-zinc-400">{t.trust.intro}</p>

            <div class="mt-12 space-y-9">
              {
                t.trust.points.map((point) => (
                  <div>
                    <h3 class="font-semibold tracking-tight">{point.title}</h3>
                    <p class="mt-2 leading-relaxed text-zinc-400">{point.body}</p>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="lg:sticky lg:top-24" data-reveal>
            <CommandLog label={t.trust.consoleLabel} />
          </div>
        </div>
      </div>
    </section>

    <!-- Download -->
    <section id="download">
      <div class="mx-auto max-w-3xl px-4 py-24 text-center sm:px-6 sm:py-32" data-reveal>
        <h2 class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl">{t.download.heading}</h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-pretty text-zinc-600 dark:text-zinc-400">
          {t.download.body}
        </p>

        <a
          href={DOWNLOAD_URL}
          rel="noopener"
          class="mt-9 inline-flex items-center gap-2 rounded-lg bg-brand-600 px-6 py-3.5 text-lg font-medium text-white transition-colors hover:bg-brand-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-600"
        >
          <Icon icon={ArrowDown02Icon} class="size-5" />
          {t.download.cta}
        </a>

        <p class="mt-4 text-sm text-zinc-500">{t.download.platform}</p>

        <div
          class="mt-12 rounded-xl border border-zinc-200 bg-zinc-50 p-5 text-left text-sm text-zinc-600 dark:border-zinc-800 dark:bg-zinc-900/60 dark:text-zinc-400"
        >
          <p class="font-medium text-zinc-900 dark:text-zinc-200">{t.download.smartscreenTitle}</p>
          <p class="mt-1.5 leading-relaxed">{t.download.smartscreen}</p>
        </div>
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</Base>

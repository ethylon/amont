---
import Base from "../layouts/Base.astro"
import Nav from "./Nav.astro"
import Footer from "./Footer.astro"
import { dict, DOWNLOAD_URL, localePath, downloadPath, type Locale } from "../i18n/ui"
import pkg from "../../../package.json"

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const t = dict[locale]
const paths: Record<Locale, string> = { en: downloadPath("en"), fr: downloadPath("fr") }
---

<Base locale={locale} title={t.download.pageTitle} description={t.download.pageDescription} paths={paths}>
  <Nav locale={locale} paths={paths} />

  <main id="main">
    <section class="mx-auto max-w-3xl px-4 py-24 text-center sm:px-6 sm:py-32">
      <h1 class="text-4xl font-semibold tracking-tight text-balance sm:text-5xl">
        {t.download.heading}
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-pretty text-zinc-600 dark:text-zinc-400">
        {t.download.body}
      </p>

      <a
        href={DOWNLOAD_URL}
        rel="noopener"
        class="mt-10 inline-flex items-center gap-2 rounded-lg bg-violet-600 px-6 py-3.5 text-lg font-medium text-white transition-colors hover:bg-violet-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-violet-600"
      >
        <svg
          class="size-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M12 5v14"></path>
          <path d="M19 12l-7 7-7-7"></path>
        </svg>
        {t.download.cta}
      </a>

      <p class="mt-5 font-mono text-xs text-zinc-500">
        v{pkg.version} · Windows · MIT
      </p>

      <p class="mt-3 text-sm text-zinc-500">{t.download.platform}</p>

      <div
        class="mt-12 rounded-xl border border-zinc-200 bg-zinc-50 p-5 text-left text-sm text-zinc-600 dark:border-zinc-800 dark:bg-zinc-900/60 dark:text-zinc-400"
      >
        <p class="font-medium text-zinc-900 dark:text-zinc-200">{t.download.smartscreenTitle}</p>
        <p class="mt-1.5 leading-relaxed">{t.download.smartscreen}</p>
      </div>

      <p class="mt-12">
        <a
          href={localePath(locale)}
          class="text-sm font-medium text-zinc-600 transition-colors hover:text-zinc-950 dark:text-zinc-400 dark:hover:text-white"
        >
          <span aria-hidden="true">←</span>
          {t.download.backHome}
        </a>
      </p>
    </section>
  </main>

  <Footer locale={locale} paths={paths} />
</Base>

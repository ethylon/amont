---
// Signature de la page : le motif de graphe d'Amont (lanes verticales, courbes de
// merge, nœuds), monochrome avec une seule branche violette. Purement décoratif.
// Le motif est statique et toujours visible ; l'animation (impulsions le long des
// lanes, respiration des nœuds violets) est un ornement en boucle qui part de
// l'état visible — un moteur d'animation gelé n'enlève rien.
---

<svg
  viewBox="0 0 520 900"
  fill="none"
  aria-hidden="true"
  class="pointer-events-none absolute top-0 right-0 -z-10 hidden h-full w-auto max-w-[46%] lg:block"
  style="mask-image: linear-gradient(to bottom, black 0%, black 55%, transparent 96%); -webkit-mask-image: linear-gradient(to bottom, black 0%, black 55%, transparent 96%)"
  preserveAspectRatio="xMaxYMin slice"
>
  <g class="text-zinc-300 dark:text-zinc-700" stroke="currentColor" stroke-width="2.5">
    <path d="M140 -20 V 920"></path>
    <path d="M460 -20 V 650 C 460 700, 140 700, 140 750"></path>
  </g>
  <path
    class="text-violet-500/70 dark:text-violet-400/50"
    stroke="currentColor"
    stroke-width="2.5"
    d="M140 140 C 140 190, 300 190, 300 240 V 520 C 300 570, 140 570, 140 620"
  ></path>

  <path
    class="pulse text-zinc-400 dark:text-zinc-300"
    pathLength="1"
    stroke="currentColor"
    stroke-width="3"
    stroke-linecap="round"
    d="M140 -20 V 920"
  ></path>
  <path
    class="pulse pulse-2 text-violet-500 dark:text-violet-300"
    pathLength="1"
    stroke="currentColor"
    stroke-width="3"
    stroke-linecap="round"
    d="M140 140 C 140 190, 300 190, 300 240 V 520 C 300 570, 140 570, 140 620"
  ></path>

  <g class="text-zinc-300 dark:text-zinc-700" fill="currentColor" stroke="none">
    <circle cx="140" cy="80" r="6"></circle>
    <circle cx="140" cy="320" r="6"></circle>
    <circle cx="140" cy="470" r="6"></circle>
    <circle cx="460" cy="180" r="6"></circle>
    <circle cx="460" cy="420" r="6"></circle>
    <circle cx="140" cy="750" r="6"></circle>
  </g>
  <g class="text-violet-500/80 dark:text-violet-400/60" fill="currentColor" stroke="none">
    <circle class="breathe" cx="300" cy="240" r="6"></circle>
    <circle class="breathe" style="animation-delay: -2s" cx="300" cy="380" r="6"></circle>
    <circle class="breathe" style="animation-delay: -4s" cx="140" cy="620" r="6"></circle>
  </g>
</svg>

<style>
  .pulse {
    opacity: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .pulse {
      opacity: 1;
      stroke-dasharray: 0.045 1.955;
      stroke-dashoffset: 2.045;
      animation: pulse 13s linear 2s infinite;
      filter: drop-shadow(0 0 3px currentColor) drop-shadow(0 0 9px currentColor);
    }
    .pulse-2 {
      animation-delay: 8.5s;
    }

    .breathe {
      transform-box: fill-box;
      transform-origin: center;
      animation: breathe 6s ease-in-out infinite;
    }
  }

  @keyframes pulse {
    from {
      stroke-dashoffset: 2.045;
    }
    to {
      stroke-dashoffset: -0.045;
    }
  }

  @keyframes breathe {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.6;
      transform: scale(0.8);
    }
  }
</style>

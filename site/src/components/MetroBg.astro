---
// Decorative nod to the metro-map metaphor: a few branch "lanes" merging behind the hero.
---

<svg
  viewBox="0 0 1440 720"
  fill="none"
  aria-hidden="true"
  class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-full w-full opacity-40 dark:opacity-25"
  style="mask-image: linear-gradient(to bottom, transparent, black 18%, black 72%, transparent); -webkit-mask-image: linear-gradient(to bottom, transparent, black 18%, black 72%, transparent)"
  preserveAspectRatio="xMidYMid slice"
>
  <g class="text-violet-500" stroke="currentColor" stroke-width="3">
    <path d="M-40 500 C 240 500, 330 370, 570 370 S 920 450, 1480 430"></path>
    <circle cx="570" cy="370" r="7" fill="currentColor"></circle>
    <circle cx="1050" cy="443" r="7" fill="currentColor"></circle>
  </g>
  <g class="text-sky-500" stroke="currentColor" stroke-width="3">
    <path d="M-40 560 C 280 560, 380 545, 620 460 S 1020 290, 1480 310"></path>
    <circle cx="620" cy="460" r="7" fill="currentColor"></circle>
    <circle cx="230" cy="558" r="7" fill="currentColor"></circle>
  </g>
  <g class="text-amber-500" stroke="currentColor" stroke-width="3">
    <path d="M-40 450 C 200 450, 430 290, 730 290 S 1120 370, 1480 350"></path>
    <circle cx="730" cy="290" r="7" fill="currentColor"></circle>
    <circle cx="1290" cy="355" r="7" fill="currentColor"></circle>
  </g>
  <g class="text-rose-500" stroke="currentColor" stroke-width="3">
    <path d="M-40 610 C 320 610, 520 600, 780 530 S 1180 420, 1480 440"></path>
    <circle cx="780" cy="530" r="7" fill="currentColor"></circle>
  </g>
</svg>

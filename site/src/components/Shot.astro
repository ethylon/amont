---
import { Image } from "astro:assets"
import type { ImageMetadata } from "astro"

interface Props {
  light: ImageMetadata
  dark: ImageMetadata
  alt: string
  /** Eager-load (hero / LCP image). Everything else lazy-loads. */
  eager?: boolean
  /** Show the dark capture in light theme and vice versa. */
  invert?: boolean
  sizes?: string
  class?: string
}

const {
  light,
  dark,
  alt,
  eager = false,
  invert = false,
  sizes = "(min-width: 1152px) 1104px, 96vw",
  class: className = "",
} = Astro.props

const widths = [480, 768, 1080, 1600, 2160]
const inLight = invert ? dark : light
const inDark = invert ? light : dark
---

<figure
  class:list={[
    "overflow-hidden rounded-xl border border-zinc-200 bg-zinc-50 shadow-2xl shadow-zinc-950/10 dark:border-zinc-800 dark:bg-zinc-900 dark:shadow-black/40",
    className,
  ]}
>
  <Image
    src={inLight}
    alt={alt}
    widths={widths}
    sizes={sizes}
    loading={eager ? "eager" : "lazy"}
    fetchpriority={eager ? "high" : "auto"}
    class="block w-full dark:hidden"
  />
  <Image src={inDark} alt={alt} widths={widths} sizes={sizes} loading="lazy" class="hidden w-full dark:block" />
</figure>

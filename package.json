{
  "name": "amont",
  "version": "0.16.0",
  "private": true,
  "type": "module",
  "description": "A Git history visualizer",
  "author": "Mathieu GUEY",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ethylon/amont.git"
  },
  "bugs": {
    "url": "https://github.com/ethylon/amont/issues"
  },
  "homepage": "https://github.com/ethylon/amont#readme",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "electron-vite dev",
    "mock": "vite --config vite.preview.config.mjs",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dist": "electron-vite build && electron-builder",
    "release": "electron-vite build && electron-builder --publish always"
  },
  "devDependencies": {
    "@base-ui/react": "1.6.0",
    "@electron/fuses": "^2.1.3",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/geist": "5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@hugeicons/core-free-icons": "4.2.2",
    "@hugeicons/react": "1.1.9",
    "@lingui/babel-plugin-lingui-macro": "^5.9.5",
    "@lingui/cli": "^5.9.5",
    "@lingui/core": "^5.9.5",
    "@lingui/format-po": "^5.9.5",
    "@lingui/vite-plugin": "^5",
    "@sentry/electron": "^7.15.0",
    "@sentry/vite-plugin": "^5.4.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "5.101.2",
    "@types/node": "^24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "diff2html": "^3.4.56",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-updater": "6.8.9",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "prettier": "^3.9.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "4.13.0",
    "shiki": "^4.3.1",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "7.3.6",
    "vitest": "^4.1.10",
    "zustand": "5.0.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "electron",
      "esbuild"
    ]
  }
}

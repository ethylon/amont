{
  "name": "git-graph",
  "version": "0.11.0",
  "private": true,
  "type": "module",
  "description": "Visualiseur d'historique Git",
  "author": "Mathieu GUEY",
  "main": "./out/main/index.js",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json",
    "test": "node scripts/check-refs.ts && node scripts/check-graph.ts && node scripts/check-sha256.ts",
    "dist": "electron-vite build && electron-builder",
    "release": "electron-vite build && electron-builder --publish always"
  },
  "devDependencies": {
    "@base-ui/react": "1.6.0",
    "@fontsource-variable/geist": "5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@hugeicons/core-free-icons": "4.2.2",
    "@hugeicons/react": "1.1.9",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "diff2html": "^3.4.56",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "4.13.0",
    "shiki": "^4.3.1",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "7.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}

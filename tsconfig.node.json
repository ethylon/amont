/* Le côté Node : process main, preload et scripts d'auto-contrôle. Main et preload sont en
   TypeScript strict — le contrat IPC partagé (src/shared/) compile contre les mêmes types
   que le renderer, dans les trois process. (DOM dans lib : les scripts importent des modules
   du renderer, typés contre le DOM.) */
{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/renderer/src/*"]
    }
  },
  "include": ["src/main", "src/preload", "src/shared", "scripts"]
}
